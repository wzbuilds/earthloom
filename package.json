{
  "name": "earthloom",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "vinext dev",
    "build": "vinext build",
    "build:pages": "next build",
    "start": "vinext start",
    "weave": "node scripts/weave.mjs",
    "weave:digest": "node scripts/weave.mjs --digest",
    "weave:weekly": "node scripts/weave.mjs --weekly",
    "weave:monthly": "node scripts/weave.mjs --monthly",
    "check": "tsc --noEmit",
